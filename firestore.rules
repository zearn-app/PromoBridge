rules_version = '2';

// All reads/writes to app data (users, influencers, brands, campaigns,
// requests, payments, withdrawals, notifications, settings) go through
// the Express backend using the Firebase Admin SDK, which bypasses
// these rules entirely. That's intentional: it lets the API enforce
// role checks, input validation, and payment-signature verification
// in one place instead of duplicating that logic in security rules.
//
// Because of that, the client SDK should never read/write Firestore
// directly, so we deny it here as defense in depth.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
