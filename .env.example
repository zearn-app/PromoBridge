# ---- Firebase Admin (server-side) ----
# Generate from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# IMPORTANT: paste the private key with \n literal newlines, wrapped in quotes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ---- Razorpay ----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# ---- Platform config ----
DEFAULT_COMMISSION_PERCENT=15
ADMIN_EMAILS=you@example.com,cofounder@example.com

# ---- Server ----
PORT=5000
NODE_ENV=production
CORS_ORIGIN=https://your-app.vercel.app
